---
import Layout from '~/layouts/PageLayout.astro';
import { chatbotWhatsappUrl } from '~/utils/chatbot';

const metadata = {
  title: "Chatbot — Projeto Mbiru'i",
  description: 'Agente no WhatsApp do Projeto Mbiru’i para explicar tuberculose em Guarani Kaiowá.',
};

const whatItDoes = [
  'Explica dúvidas sobre tuberculose em linguagem mais acessível.',
  'Responde em Guarani Kaiowá no canal do WhatsApp.',
  'Ajuda a circular informação em saúde no cotidiano.',
] as const;

const audiencePoints = [
  'Agentes Indígenas de Saúde que precisam de apoio rápido de informação.',
  'Pessoas da comunidade que querem um canal simples para perguntar e entender melhor.',
  'Parceiros e mediadores locais que ajudam a circular informação em território.',
] as const;

const usageSteps = [
  'Abra o WhatsApp pelo botão da página.',
  'Escreva sua dúvida sobre tuberculose em Guarani Kaiowá ou português.',
  'Use a resposta como apoio inicial e procure atendimento quando precisar de avaliação profissional.',
] as const;
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto max-w-5xl px-4">
      <p class="section-kicker">Agente no WhatsApp</p>
      <h1 class="mt-4 text-4xl leading-tight sm:text-5xl">
        Um agente no WhatsApp para explicar tuberculose em Guarani Kaiowá.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
        Desenvolvido no contexto do Projeto Mbiru'i, o agente ajuda a explicar tuberculose de forma mais acessível em um
        canal simples de usar no dia a dia.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Conversar no WhatsApp
        </a>
        <a href="mailto:contato@mbirui.ia.br" class="btn-secondary">E-mail institucional</a>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">O que ele faz</p>
          <div class="mt-4 grid gap-4">
            {
              whatItDoes.map((item) => (
                <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                  <p class="text-base leading-7 text-[color:var(--aw-color-text-default)]">{item}</p>
                </div>
              ))
            }
          </div>
        </article>

        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Para quem foi pensado</p>
          <div class="mt-4 grid gap-4">
            {
              audiencePoints.map((item) => (
                <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                  <p class="text-base leading-7 text-[color:var(--aw-color-text-default)]">{item}</p>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2rem] p-7 sm:p-9">
        <p class="section-kicker">Como usar</p>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {
            usageSteps.map((item, index) => (
              <article class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Passo {String(index + 1).padStart(2, '0')}
                </p>
                <p class="mt-3 text-base leading-7 text-[color:var(--aw-color-text-default)]">{item}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Uso responsável</p>
          <p class="mt-4 text-base leading-8 text-muted">
            A ferramenta oferece apoio informacional e não substitui avaliação clínica, diagnóstico ou atendimento em
            situações de urgência.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2rem] p-7 sm:p-9">
        <p class="section-kicker">Sobre o projeto</p>
        <p class="mt-4 max-w-3xl text-base leading-8 text-muted">
          O chatbot faz parte de uma frente maior do Projeto Mbiru'i, que articula pesquisa, tradução, formação e
          colaboração em território para apoiar o cuidado em saúde e ampliar o acesso à informação em contexto indígena.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Conversar no WhatsApp
          </a>
          <a href="mailto:contato@mbirui.ia.br" class="btn-secondary">E-mail institucional</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
