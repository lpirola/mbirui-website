---
import Layout from '~/layouts/PageLayout.astro';
import { chatbotWhatsappUrl } from '~/utils/chatbot';

const metadata = {
  title: "Chatbot — Projeto Mbiru'i",
  description: 'Acesso ao chatbot do Projeto Mbiru’i para apoio à informação em saúde indígena.',
};

const usos = [
  'Acesso inicial pelo WhatsApp.',
  'Apoio à circulação de informação em saúde.',
  'Ferramenta pública vinculada às frentes de pesquisa do projeto.',
];
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto max-w-5xl px-4">
      <p class="section-kicker">Chatbot / aplicativo</p>
      <h1 class="mt-4 text-4xl leading-tight sm:text-5xl">Acesso direto à ferramenta pública do Projeto Mbiru'i.</h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">
        O chatbot integra a frente pública do projeto e oferece uma entrada simples para interação, informação e
        circulação de conteúdo em saúde indígena.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Abrir no WhatsApp
        </a>
        <a href="mailto:nangareko@mbirui.ia.br" class="btn-secondary">E-mail institucional</a>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Como acessar</p>
          <p class="mt-4 text-base leading-8 text-muted">
            O acesso inicial do chatbot acontece pelo WhatsApp. O objetivo desta página é tornar esse caminho visível e
            explicar rapidamente o papel da ferramenta dentro do site. Esse canal é exclusivo para uso do chatbot.
          </p>
        </article>

        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Uso responsável</p>
          <p class="mt-4 text-base leading-8 text-muted">
            A ferramenta é um apoio informacional. Ela não substitui avaliação médica, protocolos clínicos ou
            atendimento profissional em situações de urgência.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2rem] p-7 sm:p-9">
        <p class="section-kicker">O que você encontra</p>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {
            usos.map((item) => (
              <article class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="text-base leading-7 text-[color:var(--aw-color-text-default)]">{item}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
