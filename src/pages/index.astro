  <section class="pb-16 sm:pb-20" id="premios">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="max-w-3xl">
          <p class="section-kicker">Prêmios</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            Os financiamentos ajudam a explicar por que as frentes de pesquisa aparecem separadas no site.
          </h2>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-2">
          {
            premios.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-[1.8rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-6 py-6 transition hover:-translate-y-0.5 hover:border-primary/40"
              >
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  {item.ano}
                </p>
                <h3 class="mt-4 text-2xl leading-tight">{item.financiador}</h3>
                <p class="mt-4 text-sm leading-7 text-muted">{item.titulo}</p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24" id="equipe">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Equipe</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            A equipe reúne pesquisadoras, pesquisadores e colaboradoras vinculados às diferentes frentes do trabalho.
          </h2>

          <div class="mt-7 grid gap-4 md:grid-cols-2">
            {
              equipe.map((nome) => (
                <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                  <p class="text-base font-semibold text-heading">{nome}</p>
                </div>
              ))
            }
          </div>
        </article>

        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8" id="contato">
          <p class="section-kicker">Contato</p>
          <h3 class="mt-4 text-3xl leading-tight">
