---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { chatbotWhatsappUrl } from '~/utils/chatbot';

const email = 'Projetoiatuberculose@gmail.com';

const premios = [
  {
    ano: 2022,
    financiador: 'Fundação Gates Global Grand Challenges',
    titulo: 'Sequenciamento Metagenômico de Nova Geração para Detectar, Identificar e Caracterizar Patógenos',
    link: 'https://gcgh.grandchallenges.org/grant/implementing-metagenomic-next-generation-sequencing-management-lung-infections-high-risk',
  },
  {
    ano: 2024,
    financiador: 'Fundação Gates Grand Challenges Brasil, Inteligência Artificial, INOVA FIOCRUZ',
    titulo:
      'Investigando o potencial de inteligência artificial para facilitar acesso à informação culturalmente adaptada sobre a tuberculose em línguas de recursos limitados no Brasil e no Moçambique',
    link: 'https://www.grandchallengesbrazil.org/projetos/investigando-o-potencial-de-inteligencia-artificial-para-facilitar-acesso-a-informacao-culturalmente-adaptada-sobre-a-tuberculose-em-linguas-de-recursos-limitados-no-brasil-e-no-mocambique/',
  },
] as const;

const equipe = [
  'Ida Viktoria Kolte',
  'Lúcia Pereira',
  'Jhon Tailor Chamorro de Aquino',
  'Gésica Aquino Martins',
  'Sidinei Vilhalva',
  'Aparecida Benites',
  'Catiane Benites',
  'Cecilia Lemes Vasques',
  'Luciana Batista Martins',
  'Isidéria Carmona',
  'Anayni Carmona Cáceres',
  'Arthur Chachamowitz Ng',
  'João Vitor Diniz Martins',
  'Ana Olivia Pascoto Esposito',
  'Gislene Garcia de Castro',
  'Eunice Atsuko Totumi Cunha',
  'Marina Castilhos Souza Umaki Zardin',
  'Lucas Pirola',
  'Paulo Cesar Basta',
] as const;

function getInitials(name: string) {
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0][0];
  return parts[0][0] + parts[parts.length - 1][0];
}

const metadata = {
  title: "Projeto Mbiru'i — portal institucional",
  description:
    "Projeto Mbiru'i: pesquisa, cuidado em saúde e chatbot no WhatsApp para ampliar o acesso à informação sobre tuberculose em Guarani Kaiowá.",
};
---

<Layout metadata={metadata}>
  <!-- Cap 1: Hero -->
  <section class="hero-viewport">
    <img
      src="/media/galeria/capacitacao-ais-coleta-sertao-amambai.jpeg"
      alt="Atividade de capacitação com agentes indígenas de saúde para coleta em mNGS no posto Sertão Amambai."
      loading="eager"
    />
    <div class="hero-content">
      <div class="container mx-auto px-4 pb-16 pt-16 sm:pb-20 sm:pt-20 lg:pb-28 lg:pt-28">
        <p class="section-kicker mb-5">Projeto Mbiru'i</p>
        <h1 class="max-w-[44rem] text-[2.75rem] leading-[0.92] sm:text-[3.75rem] lg:text-[4.5rem]">
          Pesquisa, cuidado em saúde e acesso à informação para os territórios Guarani Kaiowá.
        </h1>
        <p class="mt-5 max-w-[36rem] text-base leading-7 sm:text-lg sm:leading-8">
          O Mbiru'i articula pesquisa aplicada, tradução, formação e colaboração em território para reduzir barreiras
          no cuidado à tuberculose. Entre seus desdobramentos públicos está um chatbot no WhatsApp com informações em
          Guarani Kaiowá e português.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Testar no WhatsApp
          </a>
          <a href="#visao-missao" class="btn-secondary">Entender o projeto</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cap 2: Chatbot -->
  <section class="pb-20 pt-20 sm:pb-24 sm:pt-24">
    <div class="container mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div class="max-w-2xl">
          <p class="section-kicker">Destaque público</p>
          <h2 class="mt-5 text-3xl leading-tight sm:text-4xl">
            Um caminho público de acesso já está disponível.
          </h2>
          <p class="mt-5 text-base leading-8 text-muted">
            O principal produto público do projeto é um chatbot no WhatsApp que responde com base em documentos
            revisados e ajuda a ampliar o acesso à informação sobre tuberculose em Guarani Kaiowá.
          </p>
          <div class="mt-8 space-y-5">
            <div class="flex gap-3.5">
              <span class="mt-1 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-[color:var(--aw-color-primary)] text-xs font-bold text-white">
                1
              </span>
              <div>
                <p class="text-base font-semibold text-heading">Funciona no WhatsApp</p>
                <p class="mt-1 text-sm leading-7 text-muted">
                  O acesso acontece em um canal simples de usar, sem exigir conta nova ou instalação de outro aplicativo.
                </p>
              </div>
            </div>
            <div class="flex gap-3.5">
              <span class="mt-1 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-[color:var(--aw-color-primary)] text-xs font-bold text-white">
                2
              </span>
              <div>
                <p class="text-base font-semibold text-heading">Usa fontes revisadas</p>
                <p class="mt-1 text-sm leading-7 text-muted">
                  As respostas se apoiam em documentos aprovados e em um fluxo de revisão humana antes da indexação.
                </p>
              </div>
            </div>
            <div class="flex gap-3.5">
              <span class="mt-1 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-[color:var(--aw-color-primary)] text-xs font-bold text-white">
                3
              </span>
              <div>
                <p class="text-base font-semibold text-heading">Não substitui atendimento profissional</p>
                <p class="mt-1 text-sm leading-7 text-muted">
                  O chatbot oferece apoio informacional inicial e reforça a necessidade de procurar atendimento em
                  situações de sintomas, urgência ou diagnóstico.
                </p>
              </div>
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Testar no WhatsApp
            </a>
            <a href="/chatbot" class="btn-secondary">Como funciona o chatbot</a>
          </div>
        </div>

        <aside class="hidden lg:block">
          <div class="relative">
            <div class="overflow-hidden rounded-[2rem] border border-[color:var(--aw-color-line)] shadow-[0_1.25rem_4rem_rgb(26_22_18/0.12)]">
              <img
                src="/media/galeria/bolsistas-processo-traducao-equipe.jpeg"
                alt="Equipe em atividade de tradução e revisão de conteúdo em saúde."
                class="h-[28rem] w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="absolute -right-4 -bottom-4 rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-4 backdrop-blur-md">
              <p class="font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--aw-color-accent)]">IA e linguagem</p>
              <p class="mt-1 text-sm font-semibold text-heading">Guarani Kaiowá e português</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Cap 3: Visão e Missão (dark section) -->
  <section class="section-dark" id="visao-missao">
    <div class="container mx-auto px-4 py-20 sm:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-kicker">Visão e Missão</p>
        <h2 class="mt-5 text-3xl leading-tight sm:text-4xl">
          A pesquisa busca reduzir a carga desproporcional da tuberculose e ampliar acesso a cuidados culturalmente
          seguros nos territórios Guarani Kaiowá.
        </h2>
      </div>

      <div class="mx-auto mt-10 grid max-w-4xl gap-8 sm:grid-cols-3">
        <div class="text-center">
          <p class="stat-number">10x</p>
          <p class="stat-label">Taxa de TB acima da média nacional</p>
        </div>
        <div class="text-center">
          <p class="stat-number">50 mil</p>
          <p class="stat-label">Guarani e Kaiowá em Mato Grosso do Sul</p>
        </div>
        <div class="text-center">
          <p class="stat-number">60%</p>
          <p class="stat-label">Casos de TB confirmados laboratorialmente</p>
        </div>
      </div>

      <div class="mx-auto mt-12 grid max-w-4xl gap-8 lg:grid-cols-2">
        <div class="border-l-2 border-[rgb(207_137_99/0.5)] pl-6">
          <p class="section-kicker">Nossa visão</p>
          <div class="mt-4 space-y-4 text-sm leading-7">
            <p>
              A atenção primária à saúde nos territórios indígenas no Brasil é prestada pela Secretaria Especial de
              Saúde Indígena (SESAI), criada em 2010 como subsistema do SUS para oferecer cuidados adaptados às
              características culturais e logísticas dos territórios indígenas, promovendo também a articulação da
              medicina tradicional.
            </p>
            <p>
              Embora a tuberculose seja curável, ela continua sendo a doença infecciosa que mais mata no planeta. O
              Brasil segue entre os 30 países com maior carga da doença, e o acesso desigual ao diagnóstico e ao
              tratamento é uma das principais razões.
            </p>
            <p>
              Vislumbramos um futuro em que a tuberculose deixe de representar uma carga desproporcional nos
              territórios Guarani Kaiowá e em que as comunidades indígenas tenham acesso equitativo a serviços de
              saúde de alta qualidade e culturalmente seguros.
            </p>
          </div>
        </div>

        <div class="border-l-2 border-[rgb(207_137_99/0.5)] pl-6">
          <p class="section-kicker">Nossa missão</p>
          <div class="mt-4 space-y-4 text-sm leading-7">
            <p>
              Nossa missão é reduzir a tuberculose nos territórios Guarani Kaiowá. Enfrentar a tuberculose nesse
              contexto exige mais do que soluções biomédicas: requer parceria, inovação e respeito.
            </p>
            <p>
              Nosso trabalho baseia-se em intervenções de saúde lideradas pela comunidade e fundamentadas em
              pesquisa, desenvolvidas em estreita colaboração com as comunidades indígenas e o sistema público de
              saúde, incluindo a SESAI e o SUS.
            </p>
            <p>
              Buscamos um modelo de saúde que respeite os conhecimentos, a língua e a autonomia indígenas, e no qual
              a pesquisa sirva como instrumento de justiça social, dignidade e melhoria do bem-estar.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cap 4: Pesquisa -->
  <section class="pb-20 pt-20 sm:pb-24 sm:pt-24" id="pesquisa">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <p class="section-kicker">Pesquisa</p>
        <h2 class="mt-5 text-3xl leading-tight sm:text-4xl">
          Duas frentes de pesquisa respondem a barreiras linguísticas, diagnósticas e institucionais no cuidado à
          tuberculose e a outras infecções pulmonares.
        </h2>
      </div>

      <div class="mt-12 space-y-16">
        <div class="research-split">
          <div class="research-split-image">
            <img
              src="/media/galeria/bolsistas-processo-traducao-equipe.jpeg"
              alt="Equipe em atividade de tradução e revisão de conteúdo em saúde."
              loading="lazy"
            />
          </div>
          <div>
            <p class="section-kicker">Projeto Mbiru'i</p>
            <h3 class="mt-4 text-2xl leading-tight sm:text-3xl">IA, tradução e acesso à informação em saúde</h3>
            <p class="mt-4 text-sm leading-7 text-muted">
              Em entrevistas e grupos focais com profissionais de saúde e com a comunidade Guarani Kaiowá, foi
              relatado que a língua constitui uma grande barreira para a oferta de cuidados de saúde. Os Agentes
              Indígenas de Saúde são o primeiro, e às vezes o único, ponto de contato com o sistema de saúde.
            </p>
            <div class="research-points">
              <div class="research-point">
                <p class="text-sm leading-7">
                  <strong class="text-heading">Modelo texto-para-texto</strong> financiado pelo Ministério da Saúde
                  e apoiado pelo programa Grand Challenges Brazil da Fundação Gates. Primeira iniciativa de IA em
                  língua indígena no Brasil.
                </p>
              </div>
              <div class="research-point">
                <p class="text-sm leading-7">
                  <strong class="text-heading">Reconhecimento automático de fala</strong> para tradução por voz
                  entre português e Guarani Kaiowá, com potencial de impacto muito mais amplo.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="research-split">
          <div class="research-split-image lg:order-2">
            <img
              src="/media/galeria/processo-mngs-coleta-amostras.jpg"
              alt="Profissionais do projeto durante coleta de amostras com participantes em campo."
              loading="lazy"
            />
          </div>
          <div class="lg:order-1">
            <p class="section-kicker">Superando barreiras ao diagnóstico</p>
            <h3 class="mt-4 text-2xl leading-tight sm:text-3xl">TB e outras infecções pulmonares</h3>
            <p class="mt-4 text-sm leading-7 text-muted">
              Nos três anos antes da pandemia de COVID-19, 8,5% dos óbitos indígenas foram registrados como causas
              mal definidas. Tuberculose, pneumonia e septicemia estiveram entre as principais causas de morte por
              agente infeccioso.
            </p>
            <div class="research-points">
              <div class="research-point">
                <p class="text-sm leading-7">
                  <strong class="text-heading">Sequenciamento metagenômico</strong> para identificar patógenos
                  prevalentes em casos com sintomas de TB entre os povos Guarani e Kaiowá.
                </p>
              </div>
              <div class="research-point">
                <p class="text-sm leading-7">
                  <strong class="text-heading">Mapeamento diagnóstico e terapêutico</strong> com entrevistas e
                  grupos focais para redesenhar algoritmos adaptados ao contexto cultural.
                </p>
              </div>
              <div class="research-point">
                <p class="text-sm leading-7">
                  <strong class="text-heading">Estigma e sequelas da TB</strong> com tradução e validação de
                  instrumentos, ações de disseminação e recomendações de cuidado pós-TB.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cap 5: Prêmios (timeline) -->
  <section class="border-t border-[color:var(--aw-color-line)] pb-20 pt-20 sm:pb-24 sm:pt-24" id="premios">
    <div class="container mx-auto px-4">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)]">
        <div>
          <p class="section-kicker">Prêmios</p>
          <h2 class="mt-5 text-3xl leading-tight sm:text-4xl">
            Os financiamentos ajudam a explicar por que as frentes de pesquisa aparecem separadas no site.
          </h2>
        </div>

        <div class="timeline-track">
          {
            premios.map((item) => (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="timeline-item group block transition hover:opacity-80"
              >
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  {item.ano}
                </p>
                <h3 class="mt-3 text-xl font-semibold leading-tight text-heading group-hover:text-primary">
                  {item.financiador}
                </h3>
                <p class="mt-2 text-sm leading-7 text-muted">{item.titulo}</p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Cap 6: Equipe + Contato -->
  <section class="border-t border-[color:var(--aw-color-line)] pb-20 pt-20 sm:pb-24 sm:pt-24" id="equipe">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-3xl">
        <p class="section-kicker">Equipe</p>
        <h2 class="mt-5 text-3xl leading-tight sm:text-4xl">
          A equipe reúne pesquisadoras, pesquisadores e colaboradoras vinculados às diferentes frentes do trabalho.
        </h2>
      </div>

      <div class="equipe-grid mx-auto mt-12 max-w-5xl">
        {
          equipe.map((nome) => (
            <div class="equipe-card">
              <div class="equipe-avatar">
                <span class="initials">{getInitials(nome)}</span>
              </div>
              <p class="text-sm font-medium text-heading">{nome}</p>
            </div>
          ))
        }
      </div>

      <div class="mx-auto mt-16 max-w-xl text-center" id="contato">
        <p class="section-kicker">Contato</p>
        <h3 class="mt-4 text-2xl leading-tight">
          Para facilitar acesso a quem busca informação específica.
        </h3>
        <p class="mt-3 text-sm leading-7 text-muted">
          Se quiser entrar em contato sobre pesquisa, colaborações, materiais ou circulação pública do projeto,
          escreva para o e-mail institucional.
        </p>
        <div class="mt-6">
          <a href={`mailto:${email}`} class="btn-primary">{email}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
