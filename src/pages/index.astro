---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { chatbotWhatsappUrl } from '~/utils/chatbot';

const email = 'contato@mbirui.ia.br';

const projetos = (await getCollection('projetos')).filter((item) => item.data.status === 'ativo').slice(0, 2);
const resultados = (await getCollection('resultados'))
  .filter((item) => item.data.destaque || ['pdf', 'apresentacao', 'material-publico'].includes(item.data.categoria))
  .slice(0, 3);
const pages = await getCollection('pages');

const objetivosPage = pages.find((page) => page.slug === 'objetivos');
const objetivos = (objetivosPage?.body.split('\n').filter((line) => /^\d+\./.test(line)) ?? [])
  .slice(0, 3)
  .map((line) => line.replace(/^\d+\.\s*/, ''));

const metadata = {
  title: "Projeto Mbiru'i — portal institucional",
  description:
    'Projeto de saúde indígena que articula pesquisa, tradução e tecnologia para ampliar o acesso à informação sobre tuberculose entre comunidades Guarani Kaiowá.',
};

const problemPoints = [
  'A língua ainda é uma barreira prática para acessar informação e cuidado em saúde.',
  'A tuberculose segue pesando mais onde o diagnóstico chega tarde e o cuidado é desigual.',
  'Os AIS são centrais para mediar informação, território e atenção cotidiana, mas precisam de apoio contínuo.',
] as const;

const responsePoints = [
  {
    title: 'IA e linguagem',
    text: 'Desenvolvemos ferramentas para traduzir, explicar e adaptar informação em saúde ao contexto Guarani Kaiowá.',
  },
  {
    title: 'Pesquisa aplicada e cuidado',
    text: 'O projeto articula campo, formação e investigação para apoiar decisões melhores no território.',
  },
] as const;

const chatbotPoints = [
  'Fala Guarani Kaiowá e ajuda a explicar tuberculose com linguagem mais acessível.',
  'Funciona no WhatsApp, um canal simples para uso cotidiano.',
  'Foi pensado para apoiar AIS, comunidade e mediação local sem substituir atendimento profissional.',
] as const;

const heroGallery = [
  {
    src: '/media/galeria/capacitacao-ais-coleta-sertao-amambai.jpeg',
    alt: 'Atividade de capacitação com agentes indígenas de saúde para coleta em mNGS no posto Sertão Amambai.',
    caption: 'AIS e formação prática',
    classes: 'lg:col-span-8 lg:row-span-2',
    imageClass: 'h-72 sm:h-[22rem] lg:h-full',
  },
  {
    src: '/media/galeria/processo-mngs-coleta-amostras.jpg',
    alt: 'Profissionais do projeto durante coleta de amostras com participantes em campo.',
    caption: 'Cuidado em campo',
    classes: 'lg:col-span-4',
    imageClass: 'h-44 sm:h-48 lg:h-40',
  },
  {
    src: '/media/galeria/rezadores-amambai-rezadoras-parteiras.jpeg',
    alt: 'Grupo de rezadoras e parteiras reunidas em atividade comunitária em Amambai.',
    caption: 'Comunidade e território',
    classes: 'lg:col-span-4',
    imageClass: 'h-44 sm:h-48 lg:h-40',
  },
] as const;
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden pb-16 pt-16 sm:pb-20 sm:pt-20 lg:pb-24 lg:pt-24">
    <div class="container relative mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.18fr)_minmax(17rem,0.82fr)] lg:items-stretch">
        <div class="flex h-full max-w-4xl flex-col justify-center">
          <p class="section-kicker mb-4">Projeto Mbiru'i</p>
          <h1 class="max-w-[44rem] text-5xl leading-[0.9] sm:text-[4.5rem] lg:text-[5.2rem]">
            Saúde indígena, linguagem e tecnologia para enfrentar a tuberculose.
          </h1>
          <p class="mt-4 max-w-[38rem] text-lg leading-8 text-[color:var(--aw-color-text-default)] sm:text-[1.15rem]">
            O Projeto Mbiru'i articula pesquisa aplicada, tradução, formação e colaboração em território para apoiar o
            cuidado em saúde entre comunidades Guarani Kaiowá. Um dos desdobramentos públicos do projeto é um agente no
            WhatsApp que explica tuberculose em Guarani Kaiowá.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Conversar no WhatsApp
            </a>
            <a href="#como-funciona" class="btn-secondary">Entender o projeto</a>
          </div>
        </div>

        <aside class="flex h-full flex-col gap-4 lg:pt-2">
          <div class="editorial-frame flex-1 rounded-[2.25rem] p-4 sm:p-5">
            <div class="grid gap-4 lg:grid-cols-12 lg:grid-rows-2">
              {
                heroGallery.map((item) => (
                  <figure
                    class:list={[
                      item.classes,
                      'overflow-hidden rounded-[1.6rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)]',
                    ]}
                  >
                    <img
                      src={item.src}
                      alt={item.alt}
                      class:list={[item.imageClass, 'w-full object-cover']}
                      loading="lazy"
                    />
                    <figcaption class="px-4 py-2.5">
                      <p class="font-mono text-[0.62rem] uppercase tracking-[0.12em] text-[color:var(--aw-color-accent)]/80">
                        {item.caption}
                      </p>
                    </figcaption>
                  </figure>
                ))
              }
            </div>
          </div>
          <div class="editorial-frame rounded-[1.9rem] px-5 py-5 sm:px-6">
            <p class="section-kicker">Tese pública</p>
            <p class="mt-3 text-base leading-7 text-[color:var(--aw-color-text-default)]">
              A tecnologia não é o fim do projeto. Ela é uma ferramenta para tradução, cuidado e produção de
              conhecimento útil no território.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="problema">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">O problema</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            O projeto existe porque informação, diagnóstico e cuidado ainda não chegam da mesma forma para todos.
          </h2>
          <p class="mt-4 text-base leading-8 text-muted">
            No contexto Guarani Kaiowá, língua, território e desigualdade de acesso afetam a forma como a tuberculose e
            outras questões de saúde são explicadas e enfrentadas.
          </p>
        </article>

        <div class="grid gap-4">
          {
            problemPoints.map((item, index) => (
              <article class="rounded-[1.6rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Ponto {String(index + 1).padStart(2, '0')}
                </p>
                <p class="mt-3 text-sm leading-7 text-muted">{item}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="como-funciona">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="max-w-3xl">
          <p class="section-kicker">A resposta do projeto</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            O projeto combina linguagem, cuidado e pesquisa em uma mesma arquitetura de trabalho.
          </h2>
        </div>

        <div class="mt-9 grid gap-4 lg:grid-cols-2">
          {
            responsePoints.map((item, index) => (
              <article class="rounded-[1.7rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-6">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Eixo {String(index + 1).padStart(2, '0')}
                </p>
                <h3 class="mt-4 text-2xl leading-tight">{item.title}</h3>
                <p class="mt-4 text-sm leading-7 text-muted">{item.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="produto">
    <div class="container mx-auto px-4">
      <div
        class="rounded-[2.35rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-text-heading)] px-7 py-8 text-[color:var(--aw-color-bg-page)] shadow-[0_1.75rem_5rem_rgba(26,22,18,0.2)] sm:px-9 sm:py-10"
      >
        <div class="max-w-3xl">
          <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-secondary)]">
            Produto em destaque
          </p>
          <h2 class="mt-4 text-3xl leading-tight text-[color:var(--aw-color-bg-page)] sm:text-4xl">
            Um agente no WhatsApp para explicar tuberculose em Guarani Kaiowá.
          </h2>
          <p class="mt-5 text-base leading-8 text-[color:rgb(245_241_232_/_0.82)]">
            Desenvolvido no contexto do Projeto Mbiru'i, o agente ajuda a explicar tuberculose de forma mais acessível
            em um canal simples de usar no dia a dia.
          </p>
        </div>

        <div class="mt-9 grid gap-5 lg:grid-cols-3">
          {
            chatbotPoints.map((item) => (
              <figure class="overflow-hidden rounded-[1.7rem] border border-[color:rgb(245_241_232_/_0.12)] bg-[color:rgb(245_241_232_/_0.06)]">
                <figcaption class="p-5">
                  <p class="text-base leading-7 text-[color:var(--aw-color-bg-page)]">{item}</p>
                </figcaption>
              </figure>
            ))
          }
        </div>
          <div class="mt-7">
            <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Conversar no WhatsApp
            </a>
          </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="credibilidade">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Como o projeto trabalha</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            A proposta pública se apoia em método, colaboração e circulação responsável do conhecimento.
          </h2>
          <p class="mt-4 text-base leading-8 text-muted">
            O trabalho combina campo, formação, grupos focais, tradução e produção de materiais para sustentar o que o
            projeto aprende, testa e compartilha.
          </p>
          <p class="mt-7 text-sm leading-7 text-muted">
            A página de pesquisa aprofunda esses eixos para quem quiser mais detalhes sobre método, campo e
            investigação.
          </p>
        </article>

        <div class="grid gap-4">
          {
            objetivos.map((item, index) => (
              <article class="rounded-[1.6rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Compromisso {String(index + 1).padStart(2, '0')}
                </p>
                <p class="mt-3 text-sm leading-7 text-muted">{item}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="resultados-selecionados">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="max-w-3xl">
          <p class="section-kicker">Evidências e resultados</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            O projeto também aparece em apresentações, publicações e materiais públicos já curados para esta versão do
            site.
          </h2>
        </div>

        <div class="mt-8 grid gap-5 lg:grid-cols-3">
          {
            resultados.map(({ data }) => (
              <a
                href={data.link ?? data.arquivo ?? '/resultados'}
                class="group rounded-[1.8rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-6 py-6 transition hover:-translate-y-0.5 hover:border-primary/40"
              >
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  {data.ano}
                </p>
                <h3 class="mt-4 text-2xl leading-tight">{data.title}</h3>
                {data.descricao && <p class="mt-4 text-sm leading-7 text-muted">{data.descricao}</p>}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-24" id="contato">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[1.02fr_0.98fr]">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Contato</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            Se quiser conversar sobre pesquisa, circulação de materiais ou apoio ao projeto, este é o melhor ponto de
            contato.
          </h2>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href={`mailto:${email}`} class="btn-primary">{email}</a>
            <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              Conversar no WhatsApp
            </a>
          </div>
        </article>

        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <div
            class="mt-8 rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5"
          >
            <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">O foco</p>
            <div class="mt-4 space-y-3 text-sm leading-7 text-muted">
              <p>Projetos ativos: {projetos.map((item) => item.data.title).join(' · ')}</p>
              <p>Canal institucional para conversa, articulação e novos apoios.</p>
              <p>Versão pública mais seletiva, com menos ruído e mais ação.</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</Layout>
