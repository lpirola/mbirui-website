---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import { chatbotWhatsappUrl } from '~/utils/chatbot';

const email = 'Projetoiatuberculose@gmail.com';

const producoes = (await getCollection('producoes'))
  .map((item) => ({
    title: item.data.title,
    ano: item.data.ano,
    descricao: item.data.descricao,
    href: item.data.arquivo,
    tipo:
      item.data.tipo === 'cartilha'
        ? 'Cartilha'
        : item.data.tipo === 'livro'
          ? 'Livro'
          : item.data.tipo === 'relatorio'
            ? 'Relatório'
            : 'Documento',
  }))
  .filter((item) => Boolean(item.href))
  .sort((a, b) => b.ano - a.ano)
  .slice(0, 4);

const premios = [
  {
    ano: 2022,
    financiador: 'Fundação Gates Global Grand Challenges',
    titulo: 'Sequenciamento Metagenômico de Nova Geração para Detectar, Identificar e Caracterizar Patógenos',
    link: 'https://gcgh.grandchallenges.org/grant/implementing-metagenomic-next-generation-sequencing-management-lung-infections-high-risk',
  },
  {
    ano: 2024,
    financiador: 'Fundação Gates Grand Challenges Brasil, Inteligência Artificial, INOVA FIOCRUZ',
    titulo:
      'Investigando o potencial de inteligência artificial para facilitar acesso à informação culturalmente adaptada sobre a tuberculose em línguas de recursos limitados no Brasil e no Moçambique',
    link: 'https://www.grandchallengesbrazil.org/projetos/investigando-o-potencial-de-inteligencia-artificial-para-facilitar-acesso-a-informacao-culturalmente-adaptada-sobre-a-tuberculose-em-linguas-de-recursos-limitados-no-brasil-e-no-mocambique/',
  },
] as const;

const equipe = [
  'Ida Viktoria Kolte',
  'Lúcia Pereira',
  'Jhon Tailor Chamorro de Aquino',
  'Gésica Aquino Martins',
  'Sidinei Vilhalva',
  'Aparecida Benites',
  'Catiane Benites',
  'Cecilia Lemes Vasques',
  'Luciana Batista Martins',
  'Isidéria Carmona',
  'Anayni Carmona Cáceres',
  'Arthur Chachamowitz Ng',
  'João Vitor Diniz Martins',
  'Ana Olivia Pascoto Esposito',
  'Gislene Garcia de Castro',
  'Eunice Atsuko Totumi Cunha',
  'Marina Castilhos Souza Umaki Zardin',
  'Lucas Pirola',
  'Paulo Cesar Basta',
] as const;

const heroGallery = [
  {
    src: '/media/galeria/capacitacao-ais-coleta-sertao-amambai.jpeg',
    alt: 'Atividade de capacitação com agentes indígenas de saúde para coleta em mNGS no posto Sertão Amambai.',
    caption: 'Pesquisa em campo',
    classes: 'lg:col-span-8 lg:row-span-2',
    imageClass: 'h-72 sm:h-[22rem] lg:h-full',
  },
  {
    src: '/media/galeria/processo-mngs-coleta-amostras.jpg',
    alt: 'Profissionais do projeto durante coleta de amostras com participantes em campo.',
    caption: 'Meta-genômica',
    classes: 'lg:col-span-4',
    imageClass: 'h-44 sm:h-48 lg:h-40',
  },
  {
    src: '/media/galeria/bolsistas-processo-traducao-equipe.jpeg',
    alt: 'Equipe em atividade de tradução e revisão de conteúdo em saúde.',
    caption: 'IA e linguagem',
    classes: 'lg:col-span-4',
    imageClass: 'h-44 sm:h-48 lg:h-40',
  },
] as const;

const metadata = {
  title: "Projeto Mbiru'i — portal institucional",
  description:
    'Projeto Mbiru’i: pesquisa, cuidado em saúde e chatbot no WhatsApp para ampliar o acesso à informação sobre tuberculose em Guarani Kaiowá.',
};
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden pb-16 pt-16 sm:pb-20 sm:pt-20 lg:pb-24 lg:pt-24">
    <div class="container relative mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.16fr)_minmax(17rem,0.84fr)] lg:items-stretch">
        <div class="flex h-full max-w-4xl flex-col justify-center">
          <p class="section-kicker mb-4">Projeto Mbiru'i</p>
          <h1 class="max-w-[46rem] text-5xl leading-[0.9] sm:text-[4.5rem] lg:text-[5.15rem]">
            Pesquisa, cuidado em saúde e acesso à informação para os territórios Guarani Kaiowá.
          </h1>
          <p class="mt-4 max-w-[40rem] text-lg leading-8 text-[color:var(--aw-color-text-default)] sm:text-[1.15rem]">
            O Mbiru’i articula pesquisa aplicada, tradução, formação e colaboração em território para reduzir barreiras
            no cuidado à tuberculose. Entre seus desdobramentos públicos está um chatbot no WhatsApp com informações em
            Guarani Kaiowá e português.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Testar no WhatsApp
            </a>
            <a href="#visao-missao" class="btn-secondary">Entender o projeto</a>
          </div>
        </div>

        <aside class="flex h-full flex-col gap-4 lg:pt-2">
          <div class="editorial-frame flex-1 rounded-[2.25rem] p-4 sm:p-5">
            <div class="grid gap-4 lg:grid-cols-12 lg:grid-rows-2">
              {
                heroGallery.map((item) => (
                  <figure
                    class:list={[
                      item.classes,
                      'overflow-hidden rounded-[1.6rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)]',
                    ]}
                  >
                    <img src={item.src} alt={item.alt} class:list={[item.imageClass, 'w-full object-cover']} loading="lazy" />
                    <figcaption class="px-4 py-2.5">
                      <p class="font-mono text-[0.62rem] uppercase tracking-[0.12em] text-[color:var(--aw-color-accent)]/80">
                        {item.caption}
                      </p>
                    </figcaption>
                  </figure>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)] lg:items-start">
          <div class="max-w-3xl">
            <p class="section-kicker">Destaque público</p>
            <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
              Um caminho público de acesso já está disponível.
            </h2>
            <p class="mt-4 text-base leading-8 text-muted">
              O principal produto público do projeto é um chatbot no WhatsApp que responde com base em documentos
              revisados e ajuda a ampliar o acesso à informação sobre tuberculose em Guarani Kaiowá.
            </p>
          </div>

          <div class="grid gap-4">
            <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Funciona no WhatsApp
              </p>
              <p class="mt-3 text-sm leading-7 text-muted">
                O acesso acontece em um canal simples de usar, sem exigir conta nova ou instalação de outro aplicativo.
              </p>
            </div>
            <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Usa fontes revisadas
              </p>
              <p class="mt-3 text-sm leading-7 text-muted">
                As respostas se apoiam em documentos aprovados e em um fluxo de revisão humana antes da indexação.
              </p>
            </div>
            <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Não substitui atendimento profissional
              </p>
              <p class="mt-3 text-sm leading-7 text-muted">
                O chatbot oferece apoio informacional inicial e reforça a necessidade de procurar atendimento em
                situações de sintomas, urgência ou diagnóstico.
              </p>
            </div>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={chatbotWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Testar no WhatsApp
          </a>
          <a href="/chatbot" class="btn-secondary">Como funciona o chatbot</a>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="visao-missao">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="max-w-4xl">
          <p class="section-kicker">Visão e Missão</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            A pesquisa busca reduzir a carga desproporcional da tuberculose e ampliar acesso a cuidados culturalmente
            seguros nos territórios Guarani Kaiowá.
          </h2>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-2">
          <article class="rounded-[1.8rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] p-6">
            <p class="section-kicker">Nossa visão</p>
            <div class="mt-4 space-y-4 text-sm leading-7 text-muted">
              <p>
                A atenção primária à saúde nos territórios indígenas no Brasil é prestada pela Secretaria Especial de
                Saúde Indígena (SESAI), criada em 2010 como subsistema do SUS para oferecer cuidados adaptados às
                características culturais e logísticas dos territórios indígenas, promovendo também a articulação da
                medicina tradicional.
              </p>
              <p>
                Embora a tuberculose seja curável, ela continua sendo a doença infecciosa que mais mata no planeta. O
                Brasil segue entre os 30 países com maior carga da doença, e o acesso desigual ao diagnóstico e ao
                tratamento é uma das principais razões. As populações indígenas continuam apresentando taxas
                desproporcionalmente altas de infecções pulmonares e mortalidade associada a infecções não confirmadas.
              </p>
              <p>
                Os Guarani e Kaiowá, em Mato Grosso do Sul, constituem um dos maiores grupos indígenas do Brasil, com
                cerca de 50.000 pessoas vivendo na região sul do estado, na fronteira com o Paraguai. Condições como
                moradias superlotadas, insegurança alimentar e acesso limitado ao saneamento favorecem a transmissão da
                tuberculose, com taxas de incidência de até dez vezes a média nacional.
              </p>
              <p>
                Vislumbramos um futuro em que a tuberculose deixe de representar uma carga desproporcional nos
                territórios Guarani Kaiowá e em que as comunidades indígenas tenham acesso equitativo a serviços de
                saúde de alta qualidade e culturalmente seguros.
              </p>
            </div>
          </article>

          <article class="rounded-[1.8rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] p-6">
            <p class="section-kicker">Nossa missão</p>
            <div class="mt-4 space-y-4 text-sm leading-7 text-muted">
              <p>
                Nossa missão é reduzir a tuberculose nos territórios Guarani Kaiowá. Enfrentar a tuberculose nesse
                contexto exige mais do que soluções biomédicas: requer parceria, inovação e respeito.
              </p>
              <p>
                Nosso trabalho baseia-se em intervenções de saúde lideradas pela comunidade e fundamentadas em
                pesquisa, desenvolvidas em estreita colaboração com as comunidades indígenas e o sistema público de
                saúde, incluindo a SESAI e o SUS.
              </p>
              <p>
                Buscamos um modelo de saúde que respeite os conhecimentos, a língua e a autonomia indígenas, e no qual
                a pesquisa sirva como instrumento de justiça social, dignidade e melhoria do bem-estar.
              </p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20" id="pesquisa">
    <div class="container mx-auto px-4">
      <div class="grid gap-6">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Pesquisa</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            Duas frentes de pesquisa respondem a barreiras linguísticas, diagnósticas e institucionais no cuidado à
            tuberculose e a outras infecções pulmonares.
          </h2>
        </article>

        <div class="grid gap-6 lg:grid-cols-2">
          <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
            <p class="section-kicker">Projeto Mbiru’i</p>
            <h3 class="mt-4 text-3xl leading-tight">IA, tradução e acesso à informação em saúde</h3>
            <div class="mt-6 space-y-4 text-sm leading-7 text-muted">
              <p>
                Em entrevistas e grupos focais com profissionais de saúde e com a comunidade Guarani Kaiowá, foi
                relatado que a língua constitui uma grande barreira para a oferta de cuidados de saúde e de informações
                em saúde. A estigmatização e as diferenças culturais entre os conceitos biomédicos e os princípios da
                medicina tradicional também representam barreiras significativas ao cuidado.
              </p>
              <p>
                Os Agentes Indígenas de Saúde são o primeiro, e às vezes o único, ponto de contato com o sistema de
                saúde. Assim, desempenham papel fundamental na superação dessas barreiras, porém recebem treinamento
                limitado e têm poucas oportunidades de capacitação contínua.
              </p>
              <p>
                Um modelo de tradução baseado em IA bem-sucedido abre perspectivas para outras áreas de doenças,
                comunicação na atenção secundária e terciária, contato com serviços públicos, promoção dos direitos
                civis e humanos e valorização das línguas indígenas.
              </p>
            </div>

            <div class="mt-7 grid gap-4">
              <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Modelo de IA texto-para-texto
                </p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  Financiado pelo Ministério da Saúde do Brasil e apoiado pelo programa Grand Challenges Brazil da
                  Fundação Gates, o projeto buscou desenvolver um chatbot para fornecer informações e orientações sobre
                  tuberculose aos Agentes Indígenas de Saúde Guarani e Kaiowá em língua Guarani Kaiowá.
                </p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  Em prazo limitado e sem experiência prévia em IA, a equipe optou inicialmente por um modelo
                  texto-para-texto, com avaliação por métricas RAGAS e avaliação humana. Foi a primeira iniciativa de
                  desenvolvimento de um modelo de IA em uma língua indígena no Brasil.
                </p>
              </div>
              <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                  Modelo de reconhecimento automático de fala
                </p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  Após a prova de conceito bem-sucedida do modelo texto-para-texto, o projeto avança no
                  desenvolvimento de um modelo de tradução por voz entre português e Guarani Kaiowá, com potencial para
                  impacto muito mais amplo.
                </p>
              </div>
            </div>
          </article>

          <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
            <p class="section-kicker">Superando barreiras ao diagnóstico e tratamento</p>
            <h3 class="mt-4 text-3xl leading-tight">TB e outras infecções pulmonares</h3>
            <div class="mt-6 space-y-4 text-sm leading-7 text-muted">
              <p>
                Nos três anos que antecederam a pandemia de COVID-19, 8,5% dos óbitos indígenas foram registrados como
                causas mal definidas, e outros 20% decorreram de doenças infecciosas, parasitárias e respiratórias.
                Tuberculose, pneumonia e septicemia sem patógeno especificado estiveram entre as principais causas de
                morte por agente infeccioso.
              </p>
              <p>
                Entre 2015 e 2020, apenas cerca de 60% dos casos notificados de TB em indígenas foram confirmados
                laboratorialmente por baciloscopia, GeneXpert ou cultura. Coinfecções bacterianas, virais e fúngicas
                ampliam a complexidade dos quadros graves e mostram os limites dos métodos diagnósticos convencionais.
              </p>
              <p>
                Com este projeto, financiado por um edital Grand Challenges da Fundação Gates, acompanhamos a jornada da
                TB para pacientes, familiares e comunidade, investigando o panorama de patógenos, mapeando o processo
                diagnóstico e terapêutico, documentando o estigma e avaliando os desfechos do tratamento em pessoas
                sobreviventes da TB.
              </p>
            </div>

            <div class="mt-7 grid gap-4">
              <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="text-lg font-semibold text-heading">Sequenciamento metagenômico</p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  Utiliza sequenciamento metagenômico shotgun para identificar quais patógenos são mais prevalentes em
                  casos com sintomas de TB entre os povos Guarani e Kaiowá em Mato Grosso do Sul e orientar novos
                  algoritmos diagnósticos e terapêuticos.
                </p>
              </div>
              <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="text-lg font-semibold text-heading">Mapeamento do processo diagnóstico e terapêutico</p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  Entrevistas e grupos focais com pacientes, comunidade, lideranças religiosas, profissionais e
                  gestores de saúde permitem redesenhar algoritmos de diagnóstico e tratamento adaptados ao contexto
                  cultural e logístico.
                </p>
              </div>
              <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                <p class="text-lg font-semibold text-heading">Estigma e sequelas da TB</p>
                <p class="mt-3 text-sm leading-7 text-muted">
                  O projeto traduz e valida instrumentos de mensuração do estigma, desenvolve ações de disseminação de
                  informação e coleta dados para formular recomendações de cuidado pós-TB para sobreviventes Guarani
                  Kaiowá.
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!--section class="pb-16 sm:pb-20" id="producoes">
