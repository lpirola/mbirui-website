---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';

const resultados = (await getCollection('resultados')).sort((a, b) => b.data.ano - a.data.ano);
const galeria = (await getCollection('galeria')).filter(({ data }) =>
  ['congressos', 'eventos', 'produtos'].includes(data.categoria)
);

const grupos = [
  {
    title: 'Apresentações e PDFs',
    categorias: ['apresentacao', 'pdf'] as string[],
  },
  {
    title: 'Workshops e eventos',
    categorias: ['workshop'] as string[],
  },
  {
    title: 'Materiais públicos',
    categorias: ['material-publico'] as string[],
  },
  {
    title: 'Instagram e presença pública',
    categorias: ['instagram'] as string[],
  },
] as const;

const metadata = {
  title: "Resultados — Projeto Mbiru'i",
  description: 'Apresentações, materiais, workshops e registros públicos do Projeto Mbiru’i.',
};

const email = 'contato@mbirui.ia.br';
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden pb-14 pt-12 sm:pb-18 sm:pt-16 lg:pb-24 lg:pt-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
        <div class="max-w-4xl">
          <p class="section-kicker">Resultados</p>
          <h1 class="mt-4 max-w-4xl text-5xl leading-[0.94] sm:text-6xl">
            Materiais públicos, apresentações e registros de circulação do projeto.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
            Esta página reúne documentos e registros públicos curados a partir do acervo do projeto. Os itens foram
            selecionados para mostrar circulação, formação e diálogo sem antecipar conclusões nem publicar informação
            ainda não validada.
          </p>
        </div>

        <aside class="editorial-frame rounded-[2.25rem] p-6 sm:p-8">
          <p class="section-kicker">Panorama</p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div
              class="rounded-[1.45rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5"
            >
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Arquivos públicos
              </p>
              <p class="mt-3 text-3xl font-semibold text-heading">{resultados.length}</p>
              <p class="mt-2 text-sm leading-7 text-muted">
                Itens curados entre PDFs, apresentações, workshops e materiais públicos.
              </p>
            </div>
            <div
              class="rounded-[1.45rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5"
            >
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Registros visuais
              </p>
              <p class="mt-3 text-3xl font-semibold text-heading">{Math.min(galeria.length, 6)}</p>
              <p class="mt-2 text-sm leading-7 text-muted">
                Imagens que ajudam a mostrar presença pública, encontros e produtos do projeto.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="pb-12 sm:pb-16 lg:pb-20">
    <div class="container mx-auto max-w-6xl px-4 space-y-10">
      {
        grupos.map((grupo) => {
          const itens = resultados.filter(({ data }) => grupo.categorias.includes(data.categoria));

          if (itens.length === 0) return null;

          return (
            <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
              <div class="flex flex-col gap-4 border-b border-[color:var(--aw-color-line)] pb-6 sm:flex-row sm:items-end sm:justify-between">
                <div class="max-w-3xl">
                  <p class="section-kicker">Grupo curatorial</p>
                  <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">{grupo.title}</h2>
                </div>
                <span class="rounded-full border border-[color:var(--aw-color-line)] px-4 py-2 font-mono text-xs uppercase tracking-[0.14em] text-muted">
                  {String(itens.length).padStart(2, '0')} itens
                </span>
              </div>

              <div class="mt-8 grid gap-6 md:grid-cols-2">
                {itens.map(({ data }) => (
                  <article class="rounded-[1.7rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] p-6">
                    <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                      {data.ano}
                    </p>
                    <h3 class="mt-3 text-2xl leading-tight">{data.title}</h3>
                    {data.descricao && <p class="mt-4 text-sm leading-7 text-muted">{data.descricao}</p>}
                    {data.arquivo && (
                      <a
                        href={data.arquivo}
                        target="_blank"
                        class="mt-6 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.14em] text-primary"
                      >
                        Abrir arquivo
                        <span aria-hidden="true">↗</span>
                      </a>
                    )}
                    {data.link && (
                      <a
                        href={data.link}
                        target="_blank"
                        class="mt-6 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.14em] text-primary"
                      >
                        Abrir link
                        <span aria-hidden="true">↗</span>
                      </a>
                    )}
                  </article>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>

  <section class="pb-20 sm:pb-24">
    <div class="container mx-auto max-w-6xl px-4">
      <div class="editorial-frame rounded-[2.25rem] p-7 sm:p-9">
        <div class="max-w-3xl">
          <p class="section-kicker">Destaques visuais</p>
          <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">
            Congressos, encontros e produtos mostram como o projeto circula entre pesquisa, formação e diálogo público.
          </h2>
        </div>

        <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            galeria.slice(0, 6).map(({ data }) => (
              <figure class="overflow-hidden rounded-[1.9rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] shadow-[0_1rem_2.5rem_rgba(26,22,18,0.08)]">
                <img src={data.imagem} alt={data.alt} class="h-64 w-full object-cover" loading="lazy" />
                <figcaption class="p-5">
                  <p class="text-lg font-semibold text-heading">{data.title}</p>
                  {data.descricao && <p class="mt-3 text-sm leading-7 text-muted">{data.descricao}</p>}
                </figcaption>
              </figure>
            ))
          }
        </div>

        <div class="mt-10 flex flex-wrap gap-3 border-t border-[color:var(--aw-color-line)] pt-8">
          <a href={`mailto:${email}`} class="btn-primary">{email}</a>
          <a href="/projetos" class="btn-secondary">Ver o projeto</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
