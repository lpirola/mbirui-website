---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';

const equipeAtual = (await getCollection('equipe')).filter((pessoa) => pessoa.data.periodo === 'atual');

const metadata = {
  title: "Equipe — Projeto Mbiru'i",
  description: 'Equipe interdisciplinar ligada ao Projeto Mbiru’i.',
};
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto px-4 max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary dark:text-accent">Equipe</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Pesquisa interdisciplinar com foco em saúde indígena, linguagem e diagnóstico.
      </h1>
      <p class="mt-6 text-lg leading-8 text-gray-700 dark:text-gray-300">
        Esta página apresenta o núcleo atual do projeto em um formato institucional simples, com nome, função e vínculo
        principal.
      </p>
    </div>
  </section>

  <section class="pb-12 sm:pb-16 lg:pb-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          equipeAtual.map(({ slug, data }) => (
            <article class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-slate-900">
              {data.foto && <img src={data.foto} alt={data.nome} class="mb-5 h-24 w-24 rounded-full object-cover" />}
              <h2 class="text-xl font-semibold">
                <a href={`/equipe/${slug}`}>{data.nome}</a>
              </h2>
              <p class="mt-2 text-sm font-medium text-primary dark:text-accent">{data.papel}</p>
              {data.instituicao && <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">{data.instituicao}</p>}
              {data.bio && <p class="mt-4 text-sm text-gray-600 dark:text-gray-300">{data.bio}</p>}
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
