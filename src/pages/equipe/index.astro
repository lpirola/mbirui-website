---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';

const equipe = await getCollection('equipe');
const equipeAtual = equipe.filter((pessoa) => pessoa.data.periodo === 'atual');
const equipeAnterior = equipe.filter((pessoa) => pessoa.data.periodo === 'anterior');

const equipesProjeto = [
  {
    title: 'Projeto de inteligência artificial',
    description: 'Integrantes que contribuíram como pesquisadores e equipe de campo no eixo de IA.',
    membros: [
      'Lucia Pereira',
      'Jhon Tailor Chamorro de Aquino',
      'Sidinei Vilhalva',
      'Gésica Aquino Martins',
      'Aparecida Benites',
      'Catiane Benites',
      'Anayni Carmona Cáceres',
      'Isidéria Carmona',
      'Cecilia Lemes Vasques',
      'Luciana Batista Martins',
      'Arthur Chachamovitz Ng',
      'Lucas Pirola',
      'João Vitor Diniz Martins',
    ],
    nota: 'João Vitor Diniz Martins prestou suporte ao trabalho de campo em articulação com o outro projeto.',
  },
  {
    title: 'Projeto de meta-genômica',
    description: 'Equipe de pesquisadores vinculada ao eixo de meta-genômica.',
    membros: [
      'João Diniz Victor Martins',
      'Ana Olivia Pascoto Esposito',
      'Gislene Garcia de Castro Lichs',
      'Eunice Atsuko Totumi Cunha',
      'Marina Castilhos Souza Umaki',
      'Paulo Cesar Basta',
      'Rosa Juliana Gil Urbano',
    ],
  },
] as const;

const colaboradores = [
  {
    title: 'Agentes indígenas de saúde',
    text: 'Participam de formação, mediação local, trabalho de campo e circulação de materiais.',
  },
  {
    title: 'Pesquisadores e equipes de apoio',
    text: 'Contribuem com IA, linguagem, metodologia, diagnóstico e desenvolvimento técnico.',
  },
  {
    title: 'Parcerias institucionais',
    text: 'Sustentam articulações, treinamento, circulação pública e fortalecimento da rede do projeto.',
  },
] as const;

const metadata = {
  title: "Equipe — Projeto Mbiru'i",
  description: 'Equipe atual, integrantes dos projetos e rede de colaboradores do Projeto Mbiru’i.',
};
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto max-w-5xl px-4">
      <p class="section-kicker">Equipe</p>
      <h1 class="mt-4 text-4xl leading-tight sm:text-5xl">
        Equipe atual, integrantes dos projetos e rede de colaboração do projeto.
      </h1>
      <p class="mt-6 text-lg leading-8 text-muted">
        A página reúne o núcleo atual, a memória institucional e os integrantes vinculados aos diferentes eixos de
        pesquisa do projeto.
      </p>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2rem] p-7 sm:p-9">
        <p class="section-kicker">Equipe atual</p>
        <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {
            equipeAtual.map(({ slug, data }) => (
              <article class="rounded-[1.75rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] p-6">
                {data.foto && <img src={data.foto} alt={data.nome} class="mb-5 h-24 w-24 rounded-full object-cover" />}
                <h2 class="text-xl font-semibold">
                  <a href={`/equipe/${slug}`}>{data.nome}</a>
                </h2>
                <p class="mt-2 text-sm font-medium text-primary">{data.papel}</p>
                {data.instituicao && <p class="mt-1 text-sm text-muted">{data.instituicao}</p>}
                {data.bio && <p class="mt-4 text-sm leading-7 text-muted">{data.bio}</p>}
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="grid gap-6 lg:grid-cols-2">
        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8">
          <p class="section-kicker">Equipe anterior</p>
          {
            equipeAnterior.length > 0 ? (
              <div class="mt-6 space-y-4">
                {equipeAnterior.map(({ data }) => (
                  <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                    <p class="text-lg font-semibold text-[color:var(--aw-color-text-heading)]">{data.nome}</p>
                    <p class="mt-1 text-sm leading-6 text-muted">
                      {data.papel}
                      {data.instituicao ? ` · ${data.instituicao}` : ''}
                    </p>
                  </div>
                ))}
              </div>
            ) : (
              <p class="mt-5 text-base leading-8 text-muted">
                A seção foi preparada para registrar participantes anteriores assim que o acervo nominal estiver
                consolidado.
              </p>
            )
          }
        </article>

        <article class="editorial-frame rounded-[2rem] p-7 sm:p-8" id="colaboradores">
          <p class="section-kicker">Colaboradores</p>
          <div class="mt-6 space-y-4">
            {
              colaboradores.map((item) => (
                <div class="rounded-[1.5rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5">
                  <p class="text-lg font-semibold text-[color:var(--aw-color-text-heading)]">{item.title}</p>
                  <p class="mt-3 text-sm leading-7 text-muted">{item.text}</p>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="pb-16 sm:pb-20">
    <div class="container mx-auto px-4">
      <div class="editorial-frame rounded-[2rem] p-7 sm:p-9">
        <p class="section-kicker">Integrantes dos projetos</p>
        <div class="mt-6 grid gap-6 lg:grid-cols-2">
          {
            equipesProjeto.map((equipeProjeto) => (
              <article class="rounded-[1.75rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] p-6">
                <h2 class="text-2xl font-semibold text-[color:var(--aw-color-text-heading)]">{equipeProjeto.title}</h2>
                <p class="mt-3 text-sm leading-7 text-muted">{equipeProjeto.description}</p>
                <ul class="mt-5 space-y-3 text-sm leading-7 text-[color:var(--aw-color-text-default)]">
                  {equipeProjeto.membros.map((membro) => <li>{membro}</li>)}
                </ul>
                {equipeProjeto.nota && <p class="mt-5 text-sm leading-7 text-muted">{equipeProjeto.nota}</p>}
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
