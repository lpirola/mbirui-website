---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';

const metadata = {
  title: "Contato — Projeto Mbiru'i",
  description: 'Canal institucional para contato e colaboração.',
};
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto px-4 max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary dark:text-accent">Contato</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Entre em contato para colaboração, circulação de materiais e diálogo institucional.
      </h1>
      <p class="mt-6 text-lg leading-8 text-gray-700 dark:text-gray-300">
        Use o formulário abaixo para mensagens gerais. Para comunicação institucional, o e-mail principal do projeto é
        <a href="mailto:mbirui@fiocruz.br" class="ml-1 font-semibold text-primary hover:text-accent"
          >mbirui@fiocruz.br</a
        >.
      </p>
    </div>
  </section>

  <ContactUs
    id="form"
    title="Fale com a equipe"
    subtitle="Envie uma mensagem sobre pesquisa, parcerias, circulação de materiais ou atividades institucionais."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nome',
      },
      {
        type: 'email',
        name: 'email',
        label: 'E-mail',
      },
    ]}
    textarea={{
      label: 'Mensagem',
    }}
    disclaimer={{
      label: 'Ao enviar o formulário, você concorda com o uso das informações fornecidas para retorno institucional.',
    }}
    description="Retornos dependem da disponibilidade da equipe e do tipo de demanda."
  />

  <section class="pb-12 sm:pb-16 lg:pb-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid gap-6 md:grid-cols-3">
        <article
          class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-slate-900"
        >
          <h2 class="text-lg font-semibold">Parcerias</h2>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
            Projetos de pesquisa, circulação de materiais e cooperação institucional.
          </p>
        </article>
        <article
          class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-slate-900"
        >
          <h2 class="text-lg font-semibold">Materiais públicos</h2>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
            Solicitações relacionadas a apresentações, oficinas e materiais de comunicação.
          </p>
        </article>
        <article
          class="rounded-3xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-slate-900"
        >
          <h2 class="text-lg font-semibold">Chatbot</h2>
          <p class="mt-3 text-sm text-gray-600 dark:text-gray-300">
            Para acesso direto à ferramenta, use o link do chatbot disponível no menu principal.
          </p>
        </article>
      </div>
    </div>
  </section>
</Layout>
