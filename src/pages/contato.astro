---
import Layout from '~/layouts/PageLayout.astro';

const email = 'nangareko@mbirui.ia.br';

const metadata = {
  title: "Contato — Projeto Mbiru'i",
  description: 'Contato institucional do Projeto Mbiru’i.',
};
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden pb-20 pt-12 sm:pb-24 sm:pt-16 lg:pt-20">
    <div class="container mx-auto max-w-5xl px-4">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)]">
        <div>
          <p class="section-kicker">Contato</p>
          <h1 class="mt-4 text-5xl leading-[0.96] sm:text-6xl">Contato institucional claro, direto e sem ruído.</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
            Para colaboração, dúvidas ou articulação institucional, escreva para
            <a href={`mailto:${email}`} class="ml-1 font-semibold text-primary hover:text-accent">{email}</a>.
          </p>
          <p class="mt-4 max-w-2xl text-base leading-8 text-muted">
            O WhatsApp é usado apenas como porta de entrada para o chatbot. O contato com a equipe acontece por e-mail
            para preservar clareza institucional e registro das conversas.
          </p>

          <div class="mt-9 flex flex-wrap gap-3">
            <a href={`mailto:${email}`} class="btn-primary">{email}</a>
            <a href="/chatbot" class="btn-secondary">Acessar chatbot</a>
          </div>
        </div>

        <aside class="editorial-frame rounded-[2.25rem] p-6 sm:p-8">
          <p class="section-kicker">Como usar este canal</p>
          <div class="mt-6 grid gap-4">
            <div
              class="rounded-[1.45rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5"
            >
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Indicado para
              </p>
              <p class="mt-3 text-sm leading-7 text-muted">
                Parcerias, pesquisa acadêmica, circulação de materiais, convites institucionais e dúvidas públicas sobre
                o projeto.
              </p>
            </div>
            <div
              class="rounded-[1.45rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] px-5 py-5"
            >
              <p class="font-mono text-xs uppercase tracking-[0.16em] text-[color:var(--aw-color-accent)]">
                Não indicado para
              </p>
              <p class="mt-3 text-sm leading-7 text-muted">
                Uso do chatbot como suporte de equipe ou mensagens dispersas em canais não documentados.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
