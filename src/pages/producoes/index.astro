---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: "Produções — Projeto Mbiru'i",
  description: 'Página legada com redirecionamento editorial para Resultados.',
};
---

<Layout metadata={metadata}>
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary dark:text-accent">Produções</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Esta seção foi incorporada à página de Resultados.
      </h1>
      <p class="mt-6 text-lg leading-8 text-gray-700 dark:text-gray-300">
        Para concentrar apresentações, PDFs, workshops e materiais públicos em uma única navegação editorial, o conteúdo
        desta rota passou a ser apresentado em <a
          href="/resultados"
          class="font-semibold text-primary hover:text-accent">Resultados</a
        >.
      </p>
    </div>
  </section>
</Layout>
