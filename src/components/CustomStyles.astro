---
import '@fontsource-variable/inter';

/*
  Paleta de cores do Projeto Mbiru'i
  Baseada na imagem do logo (bacilos de tuberculose)

  | Cor                          | RGB             | HEX     |
  |------------------------------|-----------------|---------|
  | Bacilos (vermelho vibrante)  | 252, 72, 49     | #fc4821 |
  | Fundo médio (bege)           | 211, 178, 168   | #d3b2a8 |
  | Fundo dominante (off-white)  | 252, 247, 241   | #fcf7f1 |
  | Bordas/acentos (vermelho escuro) | 184, 15, 29 | #b80f1d |
*/
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
    --aw-font-heading: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;

    /* Cores principais - sistema editorial derivado do logo */
    --aw-color-primary: rgb(126 21 18);
    --aw-color-secondary: rgb(181 115 83);
    --aw-color-accent: rgb(214 59 34);

    --aw-color-text-heading: rgb(49 27 20);
    --aw-color-text-default: rgb(65 40 30);
    --aw-color-text-muted: rgb(94 66 54 / 78%);
    --aw-color-bg-page: rgb(247 240 230);

    --aw-color-bg-page-dark: rgb(31 17 15);
    --aw-color-surface: rgb(251 246 238 / 88%);
    --aw-color-surface-strong: rgb(242 229 214);
    --aw-color-line: rgb(133 69 42 / 18%);
    --aw-color-glow: rgb(179 48 25 / 12%);
    --aw-pattern-ring:
      radial-gradient(
        circle at center,
        transparent 63%,
        rgb(23 15 14 / 0.86) 63.4%,
        rgb(23 15 14 / 0.86) 64.8%,
        transparent 65.1%
      ),
      radial-gradient(
        circle at center,
        transparent 73%,
        rgb(132 24 15 / 0.95) 73.4%,
        rgb(132 24 15 / 0.95) 75.5%,
        transparent 75.8%
      ),
      repeating-conic-gradient(
        from 0deg,
        rgb(122 17 11) 0deg 8deg,
        rgb(248 242 234) 8deg 14deg,
        rgb(26 18 16) 14deg 20deg,
        rgb(248 242 234) 20deg 26deg
      );

    ::selection {
      background-color: rgb(252 72 49 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
    --aw-font-heading: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;

    --aw-color-primary: rgb(224 84 56);
    --aw-color-secondary: rgb(168 103 71);
    --aw-color-accent: rgb(255 144 106);

    --aw-color-text-heading: rgb(248 236 225);
    --aw-color-text-default: rgb(230 214 198);
    --aw-color-text-muted: rgb(230 214 198 / 72%);
    --aw-color-bg-page: rgb(31 17 15);
    --aw-color-surface: rgb(53 30 25 / 88%);
    --aw-color-surface-strong: rgb(69 38 29);
    --aw-color-line: rgb(244 219 198 / 14%);
    --aw-color-glow: rgb(224 84 56 / 10%);

    ::selection {
      background-color: rgb(252 72 49 / 50%);
      color: snow;
    }
  }

  html {
    background:
      radial-gradient(circle at top left, rgb(186 89 53 / 0.06), transparent 30%),
      radial-gradient(circle at top right, rgb(128 25 18 / 0.04), transparent 24%), var(--aw-color-bg-page);
  }

  body {
    color: var(--aw-color-text-default);
    background:
      linear-gradient(180deg, rgb(255 251 246 / 0.5), transparent 24rem),
      radial-gradient(circle at 20% 10%, rgb(179 48 25 / 0.07), transparent 20rem), var(--aw-color-bg-page);
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.55;
    background-image:
      linear-gradient(rgb(113 72 53 / 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgb(113 72 53 / 0.03) 1px, transparent 1px);
    background-size: 2rem 2rem;
    mask-image: linear-gradient(180deg, rgb(0 0 0 / 0.35), transparent 78%);
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.08;
    background-image: radial-gradient(rgb(92 51 36 / 0.95) 0.8px, transparent 0.8px);
    background-size: 18px 18px;
    mix-blend-mode: multiply;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    color: var(--aw-color-text-heading);
    font-family: var(--aw-font-heading);
    letter-spacing: -0.03em;
  }

  .section-kicker {
    color: var(--aw-color-primary);
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .editorial-frame {
    position: relative;
    overflow: clip;
    border: 1px solid var(--aw-color-line);
    background: linear-gradient(180deg, rgb(255 252 247 / 0.78), var(--aw-color-surface));
    box-shadow:
      0 25px 70px rgb(100 48 30 / 0.08),
      inset 0 1px 0 rgb(255 255 255 / 0.35);
  }

  .editorial-frame::before {
    content: '';
    position: absolute;
    inset: 1.1rem;
    border: 1px solid rgb(133 69 42 / 0.1);
    pointer-events: none;
  }

  .editorial-ring {
    position: relative;
    isolation: isolate;
  }

  .editorial-ring::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: var(--aw-pattern-ring);
    opacity: 0.95;
    pointer-events: none;
  }

  #header > div:first-child {
    border-bottom: 1px solid transparent;
  }

  #header.scroll > div:first-child {
    border-bottom-color: var(--aw-color-line);
    background: color-mix(in srgb, var(--aw-color-bg-page) 86%, white 14%);
    box-shadow: 0 0.75rem 2rem rgb(75 37 25 / 0.08);
  }

  footer {
    background: linear-gradient(180deg, rgb(255 250 244 / 0.72), rgb(243 232 220 / 0.86)), var(--aw-color-bg-page);
  }

  .dark footer {
    background: linear-gradient(180deg, rgb(48 26 22 / 0.85), rgb(31 17 15 / 1));
  }
</style>
