---
export interface Props {
  label?: string;
  class?: string;
}

const {
  label = 'Toggle Menu',
  class:
    className = 'group flex h-12 w-12 cursor-pointer flex-col items-center justify-center rounded-full border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)]',
} = Astro.props;
---

<button type="button" class={className} aria-label={label} data-aw-toggle-menu>
  <span class="sr-only">{label}</span>
  <slot>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-6 rounded-full bg-[color:var(--aw-color-text-heading)] opacity-80 transition duration-200 ease transform group-[.expanded]:translate-y-2.5 group-[.expanded]:rotate-45"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-6 rounded-full bg-[color:var(--aw-color-text-heading)] opacity-80 transition duration-200 ease transform group-[.expanded]:opacity-0"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-0.5 w-6 rounded-full bg-[color:var(--aw-color-text-heading)] opacity-80 transition duration-200 ease transform group-[.expanded]:-translate-y-2.5 group-[.expanded]:-rotate-45"
    ></span>
  </slot>
</button>
