---
import { Icon } from 'astro-icon/components';

import { UI } from 'astrowind:config';

export interface Props {
  label?: string;
  class?: string;
  iconClass?: string;
  iconName?: string;
}

const {
  label = 'Toggle between Dark and Light mode',
  class:
    className = 'inline-flex items-center rounded-full border border-[color:var(--aw-color-line)] p-2.5 text-sm text-muted transition hover:border-[color:var(--aw-color-primary)] hover:text-heading focus:outline-none focus:ring-4 focus:ring-[color:var(--aw-color-line)]',
  iconClass = 'w-6 h-6',
  iconName = 'tabler:sun',
} = Astro.props;
---

{
  !(UI.theme && UI.theme.endsWith(':only')) && (
    <button type="button" class={className} aria-label={label} data-aw-toggle-color-scheme>
      <Icon name={iconName} class={iconClass} />
    </button>
  )
}
