---
import { SITE } from 'astrowind:config';
import { Image } from 'astro:assets';
import logoImage from '~/assets/images/logo.png';
---

<span class="flex items-center">
  <Image
    src={logoImage}
    alt={SITE?.name || "Projeto Mbiru'i"}
    width={48}
    height={48}
    class="h-10 w-10 rounded-[1rem] border border-[color:var(--aw-color-line)] bg-[color:var(--aw-color-surface)] object-cover p-1.5 shadow-[0_0.75rem_2rem_rgba(26,22,18,0.08)] md:h-12 md:w-12"
  />
  <span
    class="ml-3 self-center whitespace-nowrap text-lg font-semibold tracking-[-0.03em] text-heading rtl:ml-0 rtl:mr-3 md:text-[1.05rem]"
  >
    {SITE?.name}
  </span>
</span>
