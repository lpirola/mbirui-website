---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative not-prose border-t border-[color:var(--aw-color-line)]']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative mx-auto max-w-7xl px-4 intersect-once intersect-no-queue intersect-quarter sm:px-6 motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid grid-cols-12 gap-4 gap-y-8 py-10 sm:gap-8 md:py-14">
      <div class="col-span-12 lg:col-span-5">
        <div class="mb-3">
          <a class="inline-block text-2xl font-semibold tracking-[-0.04em] text-heading" href={getHomePermalink()}>
            {SITE?.name}
          </a>
        </div>
        <p class="max-w-md text-sm leading-7 text-muted">
          Plataforma institucional de pesquisa, memória e colaboração em saúde indígena, com foco em linguagem, cuidado,
          tuberculose e circulação pública do conhecimento.
        </p>
        <div class="mt-4 flex flex-wrap gap-2 text-sm text-muted">
          {
            secondaryLinks.map(({ text, href }) => (
              <>
                <a
                  class="rounded-full border border-[color:var(--aw-color-line)] px-3 py-1.5 transition duration-150 ease-in-out hover:border-[color:var(--aw-color-primary)] hover:text-heading"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <div class="mb-3 font-mono text-xs uppercase tracking-[0.14em] text-[color:var(--aw-color-accent)]">
              {title}
            </div>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm">
                {links.map(({ text, href, ariaLabel }) => (
                  <li class="mb-3">
                    <a
                      class="text-muted transition duration-150 ease-in-out hover:text-heading"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
    <div class="border-t border-[color:var(--aw-color-line)] py-6 md:flex md:items-center md:justify-between md:py-8">
      {
        socialLinks?.length ? (
          <ul class="mb-4 flex -ml-2 md:order-1 md:mb-0 md:ml-4 rtl:-mr-2 rtl:ml-0 rtl:md:ml-0 rtl:md:mr-4">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="inline-flex items-center rounded-full border border-[color:var(--aw-color-line)] p-2.5 text-sm text-muted focus:outline-none focus:ring-4 focus:ring-[color:var(--aw-color-line)] hover:border-[color:var(--aw-color-primary)] hover:text-heading"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="mr-4 text-sm text-muted">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
